	pages = {371--399},
}

@article{bordon_college-major_2015,
	title = {College-{Major} {Choice} to {College}-{Then}-{Major} {Choice}},
	volume = {82},
	issn = {0034-6527},
	url = {https://doi.org/10.1093/restud/rdv023},
	doi = {10.1093/restud/rdv023},
	abstract = {Many countries use college-major-specific admissions policies that require a student to choose a college-major pair jointly. Given the potential of student-major mismatches, we explore the equilibrium effects of postponing student choice of major. We develop a sorting equilibrium model under the college-major-specific admissions regime, allowing for match uncertainty and peer effects. We estimate the model using Chilean data. We introduce the counterfactual regime as a Stackelberg game in which a social planner chooses college-specific admissions policies and students make enrolment decisions, learn about their fits to various majors before choosing one. Our estimates indicate that switching from the baseline to the counterfactual regime leads to a 1\% increase in average student welfare and that it is more likely to benefit female, low-income and/or low-ability students.},
	number = {4},
	urldate = {2026-02-06},
	journal = {The Review of Economic Studies},
	author = {Bordon, Paola and Fu, Chao},
	month = oct,
	year = {2015},
	pages = {1247--1288},
	file = {Full Text PDF:C\:\\Users\\xd-br\\Zotero\\storage\\2YKZJBWF\\Bordon and Fu - 2015 - College-Major Choice to College-Then-Major Choice.pdf:application/pdf},
}

@article{ersoy_opening_2025,
	title = {Opening the black box of college major choice: {Evidence} from an information intervention},
	volume = {231},
	issn = {01672681},
	shorttitle = {Opening the black box of college major choice},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0167268124004141},
	doi = {10.1016/j.jebo.2024.106800},
	abstract = {This study examines the role of job-related and non-job-related factors in college major choice. Using a staggered intervention, we provide students information on various aspects of majors and assess the impact of different pieces of information on their stated choices. We show that major choices depend on a wide set of factors, especially for students who are initially unsure about their major choice. The non-job-related factors, such as a major’s course difficulty and gender composition, are particularly important to students. Male and female students value different major characteristics in different ways. Female students – particularly those with below-median high school GPA – avoid majors that are more difficult than they originally believed, while male students are averse to majors with more female faculty but prefer those with more female students. Our findings help us understand gender gaps in college major choice and have a number of implications for researchers and policymakers seeking to study major choice or influence those choices.},
	language = {en},
	urldate = {2026-02-04},
	journal = {Journal of Economic Behavior \& Organization},
	author = {Ersoy, Fulya and Speer, Jamin D.},
	month = mar,
	year = {2025},
	pages = {106800},
	file = {PDF:C\:\\Users\\xd-br\\Zotero\\storage\\XUA226MV\\Ersoy and Speer - 2025 - Opening the black box of college major choice Evidence from an information intervention.pdf:application/pdf},
}

