@article{abdulkadiroglu_breaking_2022,
	title = {Breaking {Ties}: {Regression} {Discontinuity} {Design} {Meets} {Market} {Design}},
	volume = {90},
	copyright = {2022 The Econometric Society},
	issn = {1468-0262},
	shorttitle = {Breaking {Ties}},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.3982/ECTA17125},
	doi = {10.3982/ECTA17125},
	abstract = {Many schools in large urban districts have more applicants than seats. Centralized school assignment algorithms ration seats at over-subscribed schools using randomly assigned lottery numbers, non-lottery tie-breakers like test scores, or both. The New York City public high school match illustrates the latter, using test scores and other criteria to rank applicants at the city's screened schools, combined with lottery tie-breaking at the rest. We show how to identify causal effects of school attendance in such settings. Our approach generalizes regression discontinuity methods to allow for multiple treatments and multiple running variables, some of which are randomly assigned. The key to this generalization is a local propensity score that quantifies the school assignment probabilities induced by lottery and non-lottery tie-breakers. The utility of the local propensity score is demonstrated in an assessment of the predictive value of New York City's school report cards. Schools that earn the highest report card grade indeed improve SAT math scores and increase graduation rates, though by much less than OLS estimates suggest. Selection bias in OLS estimates of grade effects is egregious for screened schools.},
	language = {en},
	number = {1},
	urldate = {2026-03-28},
	journal = {Econometrica},
	author = {Abdulkadiro\u{g}lu, Atila and Angrist, Joshua D. and Narita, Yusuke and Pathak, Parag},
	year = {2022},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.3982/ECTA17125},
	keywords = {deferred acceptance, Propensity score, research design, school choice, school quality},
	pages = {117--151},
}
