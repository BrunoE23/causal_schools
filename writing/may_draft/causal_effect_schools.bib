	file = {Full Text:C\:\\Users\\xd-br\\Zotero\\storage\\NWP4A6GQ\\Angrist et al. - 2016 - Stand and Deliver Effects of Boston’s Charter High Schools on College Preparation, Entry, and Choic.pdf:application/pdf},
}

@article{dobbie_medium-term_2015,
